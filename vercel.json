{
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "env": {
    "NEXT_PUBLIC_DISABLE_THREE_JS": "false"
  },
  "functions": {
    "src/app/api/audits/*/stream/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/webhooks/stripe/route.ts": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/webhooks/stripe",
      "headers": [
        {
          "key": "x-vercel-body-parser-bypass",
          "value": "1"
        }
      ]
    }
  ]
}
