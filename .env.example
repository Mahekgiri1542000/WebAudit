# ─── Database (Neon) ──────────────────────────────────────────────────────────
# PgBouncer pooled — all app queries
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
# Direct — prisma migrate + seed ONLY
DATABASE_URL_UNPOOLED=postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=false

# ─── Auth (Auth.js v5) ────────────────────────────────────────────────────────
NEXTAUTH_SECRET=change-me-to-32-plus-random-bytes-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# ─── Google APIs ──────────────────────────────────────────────────────────────
GOOGLE_PAGESPEED_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=

# ─── VirusTotal (optional — Starter+ dual malware check) ──────────────────────
VIRUSTOTAL_API_KEY=

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Create these products + prices in your Stripe Dashboard
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=alerts@yourdomain.com

# ─── Rankings (SerpAPI) ───────────────────────────────────────────────────────
SERPAPI_KEY=

# ─── AI Suggestions (Claude — Pro/Agency plans only) ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Queue (Upstash Redis) ────────────────────────────────────────────────────
# Use rediss:// (TLS) in production
REDIS_URL=rediss://default:password@your-endpoint.upstash.io:6379

# ─── DB Seed ──────────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=change-me-min-16-chars

# ─── Optional ─────────────────────────────────────────────────────────────────
# Set to 'true' on low-spec preview deployments to disable Three.js canvas
NEXT_PUBLIC_DISABLE_THREE_JS=false
